# Exemplo de variáveis de ambiente para o pipeline ENEM
# Ajuste os caminhos conforme sua máquina

# Pasta onde estão os arquivos brutos (microdados). Padrão: ../dados_brutos
PASTA_BRUTOS=../dados_brutos

# Pasta de trabalho do pipeline (onde ficam `dados/` e `agregados`)
PASTA_DADOS=./dados

# Pasta onde os parquets agregados serão escritos
PASTA_AGREGADOS=./dados/agregados

# Diretório público onde o frontend espera os dados (docs/data)
WEB_DATA=./docs/data

# Credenciais AIO (opcional; para extrair N_PARTICIPANTES com --com-login)
# Copie este arquivo para .env e preencha (NAO commite o .env)
# Opcao A (recomendada): cookie _aio_session do navegador
AIO_SESSION=
# Opcao B: login e-mail/senha em https://www.aio.com.br/users/sign_in
AIO_EMAIL=
AIO_PASSWORD=
